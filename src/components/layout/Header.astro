---
const baseUrl = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;

const navItems = [
  { label: "Experiencias", href: "#experiencias" },
  { label: "Galería", href: "#galeria" },
  { label: "Momentos", href: "#momentos" },
  { label: "Reservar", href: "#reservar" },
];
---

<header class="fixed left-0 top-0 z-50 w-full px-4 py-4">
  <div class="mx-auto flex max-w-7xl items-center justify-between rounded-full border border-white/50 bg-white/80 px-5 py-3 shadow-lg shadow-sky-900/5 backdrop-blur-xl">
    <a href={baseUrl} class="flex items-center gap-3" aria-label="Ir al inicio de Caribe Mid">
      <img
        src={`${baseUrl}images/logo/logo-caribemid-menu.png`}
        alt="Caribe Mid Viajes & planner"
        class="h-12 w-auto"
        width="160"
        height="48"
      />
    </a>

    <nav class="hidden items-center gap-8 text-sm font-semibold text-[var(--color-deep-blue)] md:flex">
      {navItems.map((item) => (
        <a href={item.href} class="transition hover:text-[var(--color-coral)]">
          {item.label}
        </a>
      ))}
    </nav>

    <a
      href="#reservar"
      class="rounded-full bg-[var(--color-coral)] px-5 py-3 text-sm font-bold text-white shadow-md transition hover:-translate-y-0.5 hover:shadow-lg"
    >
      Reservar ahora
    </a>
  </div>
</header>