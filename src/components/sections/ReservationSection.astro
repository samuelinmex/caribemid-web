---
const phoneNumber = "5210000000000";

const whatsappMessage =
  "Hola Caribe Mid, quiero vivir una experiencia única e irrepetible. Me gustaría que me ayuden a diseñar un momento inolvidable cuidando cada detalle.";

const whatsappUrl = `https://wa.me/${phoneNumber}?text=${encodeURIComponent(whatsappMessage)}`;

const steps = [
  {
    label: "Paso 1",
    title: "Cuéntanos tu sueño",
    description:
      "Una celebración, una sorpresa, una escapada o un momento que quieres recordar para siempre.",
  },
  {
    label: "Paso 2",
    title: "Diseñamos la experiencia",
    description:
      "Cuidamos cada detalle para que el momento se sienta personal, fluido y especial.",
  },
  {
    label: "Paso 3",
    title: "Confirmas y disfrutas",
    description:
      "Te acompañamos en el proceso para que solo te enfoques en vivir algo inolvidable.",
  },
];
---

<section id="reservar" class="reservation-section relative overflow-hidden bg-[var(--color-deep-blue)] px-6 py-28 text-white">
  <div class="pointer-events-none absolute inset-0">
    <div class="absolute left-[-12rem] top-[-10rem] h-[32rem] w-[32rem] rounded-full bg-[var(--color-coral)]/25 blur-3xl"></div>
    <div class="absolute right-[-14rem] bottom-[-12rem] h-[36rem] w-[36rem] rounded-full bg-[var(--color-sky)]/20 blur-3xl"></div>
    <div class="absolute left-[45%] top-[20%] h-96 w-96 rounded-full bg-white/5 blur-3xl"></div>
  </div>

  <div class="relative mx-auto grid max-w-7xl gap-12 lg:grid-cols-[0.95fr_1.05fr] lg:items-center">
    <div class="max-w-2xl">
      <p class="text-sm font-black uppercase tracking-[0.32em] text-[var(--color-coral)]">
        Empecemos a hacerlo realidad
      </p>

      <h2 class="mt-5 text-4xl font-black leading-tight tracking-tight md:text-6xl">
        Tu sueño empieza
        <span class="block text-[var(--color-coral)]">
          con una conversación.
        </span>
      </h2>

      <p class="mt-7 text-lg leading-8 text-white/75">
        Nos cuentas lo que imaginas y nosotros nos encargamos del resto:
        planeación, detalles, recomendaciones y una experiencia diseñada para ser
        única, irrepetible e inolvidable.
      </p>

      <div class="mt-9 flex flex-col gap-4 sm:flex-row">
        <a
          href={whatsappUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center justify-center rounded-full bg-white px-8 py-4 text-base font-black text-[var(--color-deep-blue)] shadow-xl transition hover:-translate-y-1 hover:bg-[var(--color-cream)]"
        >
          Diseñar por WhatsApp →
        </a>

        <a
          href="#momentos"
          class="inline-flex items-center justify-center rounded-full border border-white/25 bg-white/10 px-8 py-4 text-base font-black text-white backdrop-blur-xl transition hover:-translate-y-1 hover:bg-white hover:text-[var(--color-deep-blue)]"
        >
          Ver momentos
        </a>
      </div>
    </div>

    <div class="reservation-card relative overflow-hidden rounded-[2.75rem] border border-white/15 bg-white/10 p-5 shadow-2xl shadow-black/10 backdrop-blur-2xl md:p-7">
      <div class="absolute right-[-5rem] top-[-5rem] h-56 w-56 rounded-full bg-[var(--color-coral)]/35 blur-3xl"></div>
      <div class="absolute bottom-[-6rem] left-[-6rem] h-64 w-64 rounded-full bg-[var(--color-sky)]/25 blur-3xl"></div>

      <div class="relative z-10 grid gap-5 md:grid-cols-3">
        {steps.map((step) => (
          <article class="rounded-[1.75rem] border border-white/10 bg-white/10 p-5 backdrop-blur-xl transition hover:-translate-y-1 hover:bg-white/15">
            <p class="text-xs font-black uppercase tracking-[0.24em] text-[var(--color-coral)]">
              {step.label}
            </p>

            <h3 class="mt-4 text-xl font-black leading-tight text-white">
              {step.title}
            </h3>

            <p class="mt-4 text-sm leading-6 text-white/68">
              {step.description}
            </p>
          </article>
        ))}
      </div>

      <div class="relative z-10 mt-5 overflow-hidden rounded-[2rem] bg-[var(--color-coral)] p-6 text-white md:p-7">
        <div class="absolute right-[-3rem] top-[-3rem] h-32 w-32 rounded-full bg-white/20 blur-2xl"></div>

        <div class="relative grid gap-6 md:grid-cols-[1fr_auto] md:items-center">
          <div>
            <p class="text-xs font-black uppercase tracking-[0.24em] text-white/75">
              Atención profesional
            </p>

            <h3 class="mt-3 text-2xl font-black leading-tight md:text-3xl">
              Queremos ser la mejor agencia del Caribe haciendo realidad tus sueños.
            </h3>

            <p class="mt-4 max-w-2xl text-sm leading-6 text-white/80">
              Cada experiencia se diseña con intención, sensibilidad y la profesionalidad
              que nos caracteriza.
            </p>
          </div>

          <a
            href={whatsappUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex whitespace-nowrap rounded-full bg-white px-7 py-4 text-sm font-black text-[var(--color-deep-blue)] shadow-lg transition hover:-translate-y-1 hover:bg-[var(--color-cream)]"
          >
            Quiero empezar →
          </a>
        </div>
      </div>

      <p class="relative z-10 mt-5 text-center text-xs leading-5 text-white/50">
        Próximamente podremos integrar pagos en línea, anticipos y confirmaciones automáticas.
      </p>
    </div>
  </div>
</section>