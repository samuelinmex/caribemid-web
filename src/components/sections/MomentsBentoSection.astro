---
const phoneNumber = "5210000000000";

const moments = [
  {
    title: "Sueño frente al mar",
    description:
      "Una experiencia diseñada para quienes imaginan un momento especial con arena, brisa, atardecer y detalles perfectamente cuidados.",
    label: "Mar",
    accent: "bento-coral",
    featured: true,
    message:
      "Hola Caribe Mid, quiero vivir una experiencia única frente al mar. Me gustaría que me ayuden a diseñar algo especial e inolvidable.",
  },
  {
    title: "Romance inolvidable",
    description:
      "Para aniversarios, propuestas, sorpresas o escapadas en pareja donde cada detalle debe sentirse personal.",
    label: "Romance",
    accent: "bento-pink",
    featured: false,
    message:
      "Hola Caribe Mid, quiero planear una experiencia romántica única e inolvidable. ¿Me pueden ayudar?",
  },
  {
    title: "Calma y naturaleza",
    description:
      "Momentos inspirados en la tranquilidad del agua, la belleza natural y la sensación de desconectar por completo.",
    label: "Calma",
    accent: "bento-blue",
    featured: false,
    message:
      "Hola Caribe Mid, me interesa una experiencia de calma, naturaleza y desconexión. Quiero conocer opciones.",
  },
  {
    title: "Celebración a la medida",
    description:
      "Creamos celebraciones memorables cuidando la ambientación, la intención y los detalles que hacen que todo se sienta único.",
    label: "Celebrar",
    accent: "bento-orange",
    featured: false,
    message:
      "Hola Caribe Mid, quiero organizar una celebración a la medida. Busco una experiencia única e irrepetible.",
  },
  {
    title: "Experiencia para compartir",
    description:
      "Planes para familia, amigos o grupos que quieren vivir algo especial, cómodo y lleno de momentos memorables.",
    label: "Compartir",
    accent: "bento-sky",
    featured: false,
    message:
      "Hola Caribe Mid, quiero una experiencia especial para compartir con familia o amigos. ¿Qué pueden recomendarme?",
  },
];

function getWhatsappUrl(message: string) {
  return `https://wa.me/${phoneNumber}?text=${encodeURIComponent(message)}`;
}
---

<section id="momentos" class="relative overflow-hidden bg-[var(--color-cream)] px-6 py-28">
  <div class="pointer-events-none absolute inset-0">
    <div class="absolute left-[-10rem] top-24 h-96 w-96 rounded-full bg-[var(--color-coral)]/20 blur-3xl"></div>
    <div class="absolute right-[-12rem] top-40 h-[30rem] w-[30rem] rounded-full bg-[var(--color-ocean)]/15 blur-3xl"></div>
    <div class="absolute bottom-[-10rem] left-[35%] h-[28rem] w-[28rem] rounded-full bg-[var(--color-flamingo)]/20 blur-3xl"></div>
  </div>

  <div class="relative mx-auto max-w-7xl">
    <div class="grid gap-10 lg:grid-cols-[0.9fr_1.1fr] lg:items-end">
      <div>
        <p class="text-sm font-black uppercase tracking-[0.3em] text-[var(--color-ocean)]">
          Elige cómo quieres recordarlo
        </p>

        <h2 class="mt-4 max-w-3xl text-4xl font-black leading-tight tracking-tight text-[var(--color-deep-blue)] md:text-6xl">
          Haz clic en el sueño
          <span class="block bg-gradient-to-r from-[var(--color-coral)] via-[var(--color-flamingo)] to-[var(--color-ocean)] bg-clip-text text-transparent">
            que quieres hacer realidad.
          </span>
        </h2>
      </div>

      <div class="rounded-[2rem] border border-white/80 bg-white/60 p-6 shadow-xl shadow-sky-950/5 backdrop-blur-xl">
        <p class="text-lg leading-8 text-slate-600">
          Cada opción inicia una conversación personalizada por WhatsApp.
          Nos cuentas lo que imaginas y nosotros nos encargamos de transformarlo
          en una experiencia cuidada hasta el último detalle.
        </p>

        <a
          href="#reservar"
          class="mt-6 inline-flex rounded-full bg-[var(--color-deep-blue)] px-7 py-4 text-sm font-black text-white shadow-xl transition hover:-translate-y-1 hover:bg-[var(--color-ocean)]"
        >
          Empezar mi experiencia →
        </a>
      </div>
    </div>

    <div class="mt-14 grid gap-6 lg:grid-cols-3">
      {
        moments.map((moment, index) => (
          <a
            href={getWhatsappUrl(moment.message)}
            target="_blank"
            rel="noopener noreferrer"
            aria-label={`Diseñar por WhatsApp: ${moment.title}`}
            class={`bento-card ${moment.accent} group relative flex min-h-[22rem] overflow-hidden rounded-[2.25rem] border border-white/80 p-7 shadow-xl shadow-sky-950/5 backdrop-blur-xl transition duration-500 hover:-translate-y-2 hover:shadow-2xl ${
              moment.featured ? "lg:col-span-2" : ""
            }`}
          >
            <div class="bento-light absolute inset-0 opacity-0 transition duration-500 group-hover:opacity-100"></div>

            <div class="bento-shape absolute -right-16 -top-16 h-56 w-56 rounded-full transition duration-700 group-hover:scale-125"></div>
            <div class="bento-shape-secondary absolute -bottom-20 left-6 h-48 w-48 rounded-full transition duration-700 group-hover:scale-125"></div>

            <div class="relative z-10 flex w-full flex-col justify-between">
              <div class="flex items-start justify-between gap-5">
                <span class="rounded-full border border-white/70 bg-white/70 px-4 py-2 text-xs font-black uppercase tracking-[0.2em] text-[var(--color-ocean)] shadow-sm backdrop-blur">
                  {moment.label}
                </span>

                <span class="text-5xl font-black leading-none text-white/60">
                  0{index + 1}
                </span>
              </div>

              <div class="mt-12">
                <h3 class={`${moment.featured ? "max-w-2xl text-4xl md:text-5xl" : "text-3xl"} font-black leading-tight tracking-tight text-[var(--color-deep-blue)]`}>
                  {moment.title}
                </h3>

                <p class={`${moment.featured ? "max-w-2xl text-base" : "text-sm"} mt-5 leading-7 text-slate-700`}>
                  {moment.description}
                </p>

                <div class="mt-8 inline-flex w-fit items-center rounded-full bg-white/75 px-6 py-3 text-sm font-black text-[var(--color-ocean)] shadow-sm backdrop-blur transition group-hover:bg-[var(--color-deep-blue)] group-hover:text-white">
                  Diseñar por WhatsApp
                  <span class="ml-2 transition group-hover:translate-x-1">→</span>
                </div>
              </div>
            </div>
          </a>
        ))
      }
    </div>
  </div>
</section>