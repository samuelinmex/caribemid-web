---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Caribe Mid | Experiencias únicas en el Caribe",
  description = "Creamos experiencias únicas e irrepetibles en el Caribe, cuidando cada detalle para convertir los sueños de nuestros clientes en momentos inolvidables.",
} = Astro.props;

const baseUrl = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href={`${baseUrl}favicon.svg`} />
    <title>{title}</title>
  </head>

  <body>
    <slot />
  </body>
</html>