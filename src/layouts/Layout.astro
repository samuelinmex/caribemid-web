---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Caribe Mid | Experiencias que se viven",
  description = "Diseñamos experiencias memorables en el Caribe para celebrar, sorprender y reservar momentos únicos.",
} = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
  </head>

  <body>
    <slot />
  </body>
</html>